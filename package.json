{
  "name": "comit.ai",
  "version": "1.0.0",
  "description": "AI powered conventional commit message generator using Groq LLM",
  "main": "index.js",
  "type": "module",
  "bin": {
    "comit": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "keywords": [
    "git",
    "commit",
    "ai",
    "groq",
    "conventional-commits",
    "cli"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.12.4",
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "conf": "^15.1.0",
    "groq-sdk": "^1.2.1",
    "node": "^26.3.0",
    "picocolors": "^1.1.1",
    "typescript": "^6.0.3"
  },
  "devDependencies": {
    "@types/conf": "^3.0.3",
    "@types/node": "^25.9.3",
    "tsx": "^4.22.4"
  }
}
